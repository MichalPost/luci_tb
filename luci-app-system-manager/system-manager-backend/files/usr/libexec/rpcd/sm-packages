#!/usr/bin/env node
'use strict';

const { rpcdMain } = require('./sm-common.js');
const { spawnSync } = require('child_process');
const fs = require('fs');
const path = require('path');

function list() {
  return {
    "pkg_installed": {},
    "pkg_available": { "query": "string" },
    "pkg_install":   { "name": "string", "dest": "string" },
    "pkg_remove":    { "name": "string" },
  };
}

function parseOpkgLine(line, status) {
  const match = line.match(/^(\S+)\s+-\s+(\S+)(?:\s+-\s+(.*))?$/);
  if (!match) return null;
  return {
    name: match[1],
    version: match[2],
    size: 0,
    description: match[3] || '',
    status,
  };
}

function pkg_installed() {
  const r = spawnSync('opkg', ['list-installed'], { encoding: 'utf8' });
  const packages = (r.stdout || '')
    .split('\n')
    .map(line => parseOpkgLine(line.trim(), 'installed'))
    .filter(Boolean);
  return { packages };
}

function runOpkg(args) {
  const r = spawnSync('opkg', args, { encoding: 'utf8', timeout: 120000 });
  const log = (r.stdout || '') + (r.stderr || '');
  if (r.status !== 0) return { result: 'error', log };
  return { result: 'ok', log };
}

function ensureUsbDest(mountpoint) {
  const destConf = '/etc/opkg/dest.conf';
  let content = '';
  try { content = fs.readFileSync(destConf, 'utf8'); } catch(_) {}
  if (!content.includes('dest usb ')) {
    fs.appendFileSync(destConf, `\ndest usb ${mountpoint}\n`);
  }
}

function usb_list() {
  const mounts = fs.readFileSync('/proc/mounts', 'utf8').split('\n');
  const devices = mounts
    .filter(line => line.split(' ')[1]?.startsWith('/mnt/'))
    .map(line => {
      const [dev, mp, , opts] = line.split(' ');
      const st = fs.statfsSync(mp);
      return {
        name: path.basename(mp),
        mountpoint: mp,
        total: st.blocks * st.bsize,
        used: (st.blocks - st.bfree) * st.bsize,
        available: st.bavail * st.bsize,
        readonly: opts.split(',').includes('ro'),
      };
    });
  return devices;
}

function pkg_install(params) {
  if (params.dest === 'usb') {
    const devices = usb_list();
    if (!devices.length) return { result: 'error', log: 'No USB device mounted' };
    ensureUsbDest(devices[0].mountpoint);
    return runOpkg(['install', '--dest', 'usb', params.name]);
  }
  return runOpkg(['install', params.name]);
}

function pkg_remove(params) {
  return runOpkg(['remove', params.name]);
}

function pkg_available(params) {
  const query = (params.query || '').toLowerCase();
  const r = spawnSync('opkg', ['list'], { encoding: 'utf8' });
  const packages = (r.stdout || '')
    .split('\n')
    .map(line => parseOpkgLine(line.trim(), 'available'))
    .filter(entry => {
      if (!entry) return false;
      if (!query) return true;
      return entry.name.toLowerCase().includes(query) ||
             entry.description.toLowerCase().includes(query);
    });
  return { packages };
}

rpcdMain(list, (method, params) => {
  switch (method) {
    case 'pkg_installed': return pkg_installed();
    case 'pkg_available': return pkg_available(params);
    case 'pkg_install':   return pkg_install(params);
    case 'pkg_remove':    return pkg_remove(params);
    default: return { result: 'error', error: 'Unknown method: ' + method };
  }
});
