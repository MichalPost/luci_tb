#!/usr/bin/env node
'use strict';

const { out, rpcdMain } = require('./sm-common.js');
const fs = require('fs');
const path = require('path');

function list() {
  return {
    "usb_list": {},
  };
}

function usb_list() {
  const mounts = fs.readFileSync('/proc/mounts', 'utf8').split('\n');
  const devices = mounts
    .filter(line => line.split(' ')[1]?.startsWith('/mnt/'))
    .map(line => {
      const [dev, mp, , opts] = line.split(' ');
      const st = fs.statfsSync(mp);
      return {
        name: path.basename(mp),
        mountpoint: mp,
        total: st.blocks * st.bsize,
        used: (st.blocks - st.bfree) * st.bsize,
        available: st.bavail * st.bsize,
        readonly: opts.split(',').includes('ro'),
      };
    });
  return { devices };
}

rpcdMain(list, (method, params) => {
  const methods = { usb_list };
  const methodFn = methods[method];
  if (!methodFn) {
    return { result: 'error', error: 'Unknown method: ' + method };
  }
  try {
    return methodFn(params);
  } catch (err) {
    return { result: 'error', error: err.code || err.message || String(err) };
  }
});
